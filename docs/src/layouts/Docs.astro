---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "zara-tracking — Plug-and-play Meta Pixel + Cloudflare Zaraz CAPI",
  description = "Drop-in tracking with shared event_id deduplication for Astro, Next.js, and any web framework.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%231877F2'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-family='-apple-system,sans-serif' font-size='17' font-weight='700' fill='white'%3EZ%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <main class="docs-shell">
      <slot />
      <footer class="docs-footer">
        <span>zara-tracking</span>
        <a href="https://github.com/rheav/zara-tracking" target="_blank" rel="noopener">
          github.com/rheav/zara-tracking
        </a>
      </footer>
    </main>
  </body>
</html>
