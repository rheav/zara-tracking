---
/* ==========================================================================
   <MetaPixel /> — Astro component
   Renders the Meta Pixel boot script + <noscript> fallback img(s).
   Mount in layout <head>. Pixel-only — DOES NOT boot the runtime
   (auto-binder, declarative events). For full plug-and-play, use
   <TrackingProvider /> instead.

   Recommended usage (pass the whole config):
     ---
     import MetaPixel from "zara-tracking/astro/MetaPixel.astro";
     import config from "../../tracking.config";
     ---
     <MetaPixel config={config} />

   Legacy form (still supported):
     <MetaPixel pixelIds={config.pixelIds} debug={config.debug} />
   ========================================================================== */

import { buildPixelInitScript } from "zara-tracking";
import type { RuntimeConfig } from "zara-tracking";

interface Props {
  /** Full RuntimeConfig — the one returned by defineTrackingConfig. */
  config?: RuntimeConfig;
  /** Legacy: pass pixelIds directly. Ignored when `config` is set. */
  pixelIds?: string[];
  /** Legacy: enable verbose console logging. Ignored when `config` is set. */
  debug?: boolean;
}

const props = Astro.props;
const pixelIds = props.config?.pixelIds ?? props.pixelIds ?? [];
const debug = props.config?.debug ?? props.debug ?? false;
const hasPixels = Array.isArray(pixelIds) && pixelIds.length > 0;

if (!hasPixels) {
  console.warn(
    "[zara-tracking] <MetaPixel> mounted with no pixelIds — nothing will fire. " +
      "Check tracking.config.{js,ts}.",
  );
}

const scriptBody = hasPixels ? buildPixelInitScript(pixelIds, debug) : "";

const noscriptHtml = pixelIds
  .map(
    (id) =>
      `<img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=${id}&ev=PageView&noscript=1" alt="" />`,
  )
  .join("");
---

{hasPixels && <script is:inline set:html={scriptBody} />}
{hasPixels && <noscript set:html={noscriptHtml} />}
