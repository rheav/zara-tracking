{
  "name": "zara-tracking",
  "version": "0.1.0",
  "description": "Plug-and-play Meta Pixel + Cloudflare Zaraz Conversions API tracking. Browser pixel + server-side CAPI deduplicated via shared event_id. Drop-in for Next.js, Astro, or any web framework.",
  "type": "module",
  "license": "MIT",
  "author": "rheav",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rheav/zara-tracking.git"
  },
  "keywords": [
    "meta",
    "pixel",
    "facebook",
    "cloudflare",
    "zaraz",
    "conversions-api",
    "capi",
    "tracking",
    "analytics",
    "astro",
    "nextjs"
  ],
  "files": [
    "dist",
    "astro",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/provider": {
      "types": "./dist/react/provider.d.ts",
      "import": "./dist/react/provider.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./astro/MetaPixel.astro": "./astro/MetaPixel.astro",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
